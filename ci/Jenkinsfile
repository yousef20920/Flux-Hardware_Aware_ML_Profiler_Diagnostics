pipeline {
  agent any

  options {
    timestamps()
    ansiColor('xterm')
  }

  environment {
    THRESHOLD = '5'
    MIN_BASELINE_US = '25'
    MIN_REGRESSION_DELTA_US = '3'
    GPU_CI_MODE = 'off'
    GPU_THRESHOLD = '5'
    GPU_MIN_BASELINE_US = '25'
    GPU_MIN_REGRESSION_DELTA_US = '3'
    BASELINE_MODE = 'ephemeral'
    TIMING_MODE = 'auto'
    CURRENT_TRACE = 'trace-current.json'
    BASELINE_TRACE = 'trace-baseline.json'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install Flux') {
      steps {
        sh '''
          python3 -m pip install -e .
        '''
      }
    }

    stage('Build Dashboard') {
      steps {
        sh '''
          cd dashboard
          npm ci
          npm run build
        '''
      }
    }

    stage('Profile Current') {
      steps {
        sh '''
          # Prime one profiling run to reduce startup/warmup skew.
          flux profile --timing-mode "$TIMING_MODE" --script examples/profile_simple_model.py --output trace-warmup.json
          flux profile --timing-mode "$TIMING_MODE" --script examples/profile_simple_model.py --output "$CURRENT_TRACE"
        '''
      }
    }

    stage('Prepare Baseline') {
      steps {
        sh '''
          if [ "$BASELINE_MODE" = "checked-in" ] && [ -f ci/baseline/trace-baseline.json ]; then
            echo "Using checked-in baseline trace."
            cp ci/baseline/trace-baseline.json "$BASELINE_TRACE"
          else
            echo "Generating baseline in this run (mode: $BASELINE_MODE)."
            flux profile --timing-mode "$TIMING_MODE" --script examples/profile_simple_model.py --output "$BASELINE_TRACE"
          fi
        '''
      }
    }

    stage('Regression Check') {
      steps {
        sh '''
          flux analyze \
            --trace "$CURRENT_TRACE" \
            --baseline "$BASELINE_TRACE" \
            --threshold "$THRESHOLD" \
            --min-baseline-us "$MIN_BASELINE_US" \
            --min-regression-delta-us "$MIN_REGRESSION_DELTA_US" \
            --gpu-ci-mode "$GPU_CI_MODE" \
            --gpu-threshold "$GPU_THRESHOLD" \
            --gpu-min-baseline-us "$GPU_MIN_BASELINE_US" \
            --gpu-min-regression-delta-us "$GPU_MIN_REGRESSION_DELTA_US"
        '''
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'trace-*.json', fingerprint: true
    }
  }
}
